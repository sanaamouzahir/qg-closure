+import torch
+import torch.nn as nn
+import torch.nn.functional as F
+import numpy as np
+
+from tqdm import tqdm
+from qg.solver.opt.basis import _state, to_spectral, to_physical
+from qg.solver.integrator.imex import CN2, AB2
+
+import qg.config as vc
+
+from qg.solver.grid.cartesian import CartesianGrid
+from qg.solver.opt.derivative import Derivative
+from qg.solver.opt.operator import ImplicitLinearOperator, define_explicit_operator
+
+from qg.solver.opt.operator.jacobian import advection_uv
+
+from qg._output.scalars import ScalarRecorder
+from qg._output.dataset import (
+    extract_obstacle_mask,
+    extract_sponge_mask,
+    build_dataset_npz,
+    write_metadata_yaml,
+)
+
+import os
+import logging
+import jpcm.draw as draw
+
+from omegaconf import DictConfig, OmegaConf
+
+class QG():
+    def __init__(self, param,
+                 grid = CartesianGrid,
+                 derivative = Derivative,
+                 implicit_linear_operator = ImplicitLinearOperator,
+                 explicit_sources = [],
+                 logger = logging.getLogger(__name__)):
+        
+        # Snapshot the raw (pre-validation) config for downstream metadata + mask
+        # extraction.  vc.validate(param).solve() mutates `param` in place,
+        # turning the bc/mask/forcing dicts into callables.  We need the dicts
+        # later to know which `Region.outlet_mask_*` to call for chi_sponge.
+        self.raw_param = OmegaConf.to_container(param, resolve=True) if isinstance(param, (DictConfig,)) else dict(param)
+        
+        param = vc.validate(param).solve()
+        self.param = param
+        self.logger = logger
+        self.logger.addHandler(logging.StreamHandler())
+        
+        self.grid = grid(**param.grid)
+        self.derivative = derivative(self.grid).to(self.grid.device)
+        self.implicit_linear_operator = implicit_linear_operator(self.grid, self.derivative, param.pde)
+        self.operator = define_explicit_operator(param, self.grid, self.derivative, self.logger,
+                                        args=(param.time.dt, self.grid, self.derivative, param.pde),
+                                        sources=explicit_sources) 
+        
+        self.dt = param.time.dt
+        self.logger.info(f"Initialized QG model with {self.grid.Nx}x{self.grid.Ny} grid on {self.grid.device}")
+
+    def step(self, state):
+        # state.dt = self.dt # Not sure if this is necessary, need to think about adaptive time stepping TODO
+
+        # vorticity step
+        explicit_source = AB2(self.operator.source(state)) # source term
+        state.qh = CN2(state.qh, explicit_source, state.dt, self.implicit_linear_operator) # Crank-Nicolson        
+        
+        # potential flow velocity step
+        # state.x_adv, state.y_adv = advection_uv(self.operator, state)
+        
+        # print(torch.max(to_physical(explicit_source)), torch.min(to_physical(explicit_source)))
+        # print(torch.max(to_physical(state.qh)), torch.min(to_physical(state.qh)))
+        
+        # update fields
+        state.update_uv()
+        # state.update_potential_flow() # also potential_flow
+        state.update_t()
+
+    def init(self):  
+        return _state(self.param.ic(self.grid, self.derivative), self.dt, self.derivative) # In spectral space
+          
+    def _run(self, prof=None):
+        save_rate = self.param.time.save_rate
+        steps = int(self.param.time.T / self.dt)  # Number of time steps
+
+        # Optional: skip saves until t >= save_after (in physical time units).
+        # The simulation still runs through the transient; we just don't save it.
+        # Defaults to 0 (save from the start) for backward compatibility.
+        save_after = float(getattr(self.param.time, 'save_after', 0.0) or 0.0)
+        save_after_step = int(save_after / self.dt)
+        # Round up to the next save-rate boundary so the first saved snapshot is
+        # at a clean t = k * save_rate * dt with t >= save_after.
+        if save_after_step > 0:
+            first_save_step = ((save_after_step + save_rate - 1) // save_rate) * save_rate
+        else:
+            first_save_step = save_rate  # the first save in the original loop
+
+        state = self.init()
+
+        # Opt-in per-step scalar recorder (SGS branch): active ONLY when the
+        # config has qg.diag.scalar_rate; otherwise rec is None and the hooks
+        # below (and in bc.py / obstacle.py via state._rec) are no-ops, keeping
+        # this path bit-identical to the unhooked solver.
+        rec = ScalarRecorder.build(self.raw_param, self.grid, int(self.param.time.T / self.dt))
+        if rec is not None:
+            state._rec = rec
+            self.logger.info(f"Scalar recorder ON: every {rec.rate} steps -> {rec.out}")
+
+        B = state.qh.shape[0]
+        # Number of save points = floor((steps - first_save_step) / save_rate) + 1.
+        # Loop iterates it from 0 to steps-2, so the last "step" candidate is
+        # it+1 = steps-1. Saves trigger when (it+1) % save_rate == 0 and
+        # (it+1) >= first_save_step.
+        if first_save_step > steps - 1:
+            T_save = 0
+        else:
+            T_save = (steps - 1 - first_save_step) // save_rate + 1
+        Ny, Nx = self.grid.Ny, self.grid.Nx
+        solution = torch.zeros([B, int(steps/save_rate)+1, 4, Ny, Nx])
+
+        # ----- diagnostics buffers ----------------------------------------- #
+        # Volume / domain integrals saved per snapshot. Negligible storage.
+        # Values are computed cheaply from quantities already in `state.out()`:
+        #   channel 0 = q (vorticity in physical space)
+        #   channel 1 = psi (streamfunction)
+        #   channel 2 = u
+        #   channel 3 = v
+        # times are pre-computed: t_k = (first_save_step + k * save_rate) * dt
+        diag_times = (first_save_step + np.arange(T_save, dtype=np.float64) * save_rate) * self.dt
+        diag_E_total = np.zeros((B, int(steps/save_rate)+1), dtype=np.float32)   # 0.5 * <|u|^2>
+        diag_Z_total = np.zeros((B, int(steps/save_rate)+1), dtype=np.float32)   # 0.5 * <q^2>
+        diag_E_zonal = np.zeros((B, int(steps/save_rate)+1), dtype=np.float32)   # 0.5 * <ubar(y)^2>
+        diag_E_eddy = np.zeros((B, int(steps/save_rate)+1), dtype=np.float32)
+        # 1D isotropic energy spectrum, retained over time. kbins set after first sample.
+        spec_kbins = None       # (n_kbins,)
+
+        # cell area for proper averaging (uniform grid)
+        dxdy = self.grid.dx * self.grid.dy
+        domain_area = self.grid.Lx * self.grid.Ly
+
+        if save_after > 0:
+            self.logger.info(
+                f"save_after={save_after}: first save at step "
+                f"{first_save_step} (t={first_save_step*self.dt:.4g}); "
+                f"saving {T_save} snapshots out of {(steps-1)//save_rate} total candidates."
+            )
+
+        for it in tqdm(range(steps)):
+            if rec is not None:
+                rec.begin_step(it, state)
+            self.step(state)
+            if rec is not None:
+                rec.after_step(it, state)
+
+            if (it+1) % save_rate == 0 and (it+1) >= first_save_step:
+                save_index = (it + 1 - first_save_step) // save_rate
+                snap = state.out()  # (B, 4, Ny, Nx)
+                solution[:, save_index, ...] = snap
+                
+                # ---- diagnostics from this snapshot ----------------------- #
+                with torch.no_grad():
+                    q = snap[:, 0]      # (B, Ny, Nx)
+                    u = snap[:, 2]
+                    v = snap[:, 3]
+                    
+                    # Total energy and enstrophy (domain averages)
+                    energy = 0.5 * (u**2 + v**2)               # per cell
+                    enstrophy = 0.5 * q**2
+                    diag_E_total[:, save_index] = energy.mean(dim=(-1, -2)).cpu().numpy()
+                    diag_Z_total[:, save_index] = enstrophy.mean(dim=(-1, -2)).cpu().numpy()
+                    
+                    # Zonal/eddy split: ubar(y) is the x-average; its energy
+                    # is the zonal-mean kinetic energy per unit area.
+                    u_zonal_mean = u.mean(dim=-1)               # (B, Ny)
+                    e_zonal_per_cell = 0.5 * u_zonal_mean**2    # (B, Ny)
+                    diag_E_zonal[:, save_index] = e_zonal_per_cell.mean(dim=-1).cpu().numpy()
+                    diag_E_eddy[:, save_index] = (
+                        diag_E_total[:, save_index] - diag_E_zonal[:, save_index]
+                    )
+                    
+                    # 1D isotropic energy spectrum, averaged over rings in k-space.
+                    # Compute |u_hat|^2 + |v_hat|^2 from the rfft of u and v.
+                    uh = torch.fft.rfft2(u, norm='ortho')         # (B, Ny, Nx//2+1)
+                    vh = torch.fft.rfft2(v, norm='ortho')
+                    spec_2d = 0.5 * (uh.real**2 +uh.imag**2 +vh.real**2+vh.imag**2)   # (B, Ny, Nx//2+1)
+                    
+                    if spec_kbins is None:
+                        # First call: set up the radial bins.
+                        # Use grid.kx/ky if they exist; else build from FFT layout.
+                        ky = torch.fft.fftfreq(Ny, d=self.grid.dy, device=spec_2d.device) * 2 * np.pi
+                        kx_pos = torch.arange(0, Nx//2+1, device=spec_2d.device) * (2*np.pi/self.grid.Lx)
+                        Kx, Ky = torch.meshgrid(kx_pos, ky, indexing='xy')   # (Ny, Nx//2+1)
+                        K = torch.sqrt(Kx**2 + Ky**2)
+                        # 0..k_max bins of width dk = min spacing
+                        dk = float(2*np.pi / max(self.grid.Lx, self.grid.Ly))
+                        k_max = float(K.max().item())
+                        spec_kbins_t = torch.arange(0.0, k_max + dk, dk, device=spec_2d.device)
+                        n_kbins = spec_kbins_t.shape[0] - 1
+                        spec_kbins = (spec_kbins_t[:-1] + spec_kbins_t[1:]).cpu().numpy() / 2
+                        # Pre-bin K so we don't recompute every step
+                        bin_idx = torch.bucketize(K, spec_kbins_t) - 1
+                        bin_idx = bin_idx.clamp(0, n_kbins - 1)
+                        # Mode-counting weight: rfft layout double-counts kx>0 modes
+                        weight = torch.where(Kx > 0, torch.tensor(2.0, device=K.device),
+                                             torch.tensor(1.0, device=K.device))
+                        # Stash for reuse next iter
+                        self._spec_bin_idx = bin_idx
+                        self._spec_weight = weight
+                        self._spec_n_kbins = n_kbins
+                    
+                    # Bin spec_2d into spec_kbins by summing weighted contributions
+                    weighted = spec_2d * self._spec_weight[None, ...]
+                    flat_b = weighted.reshape(B, -1)
+                    flat_idx = self._spec_bin_idx.reshape(-1)
+                    for b in range(B):
+                        out_b = torch.zeros(self._spec_n_kbins, device=flat_b.device, dtype=flat_b.dtype)
+                        out_b.scatter_add_(0, flat_idx, flat_b[b])
+            
+            if prof is not None:
+                prof.step()  # Step the profiler
+            
+        diagnostics = {
+            'times': diag_times,
+            'E_total': diag_E_total,
+            'Z_total': diag_Z_total,
+            'E_zonal': diag_E_zonal,
+            'E_eddy': diag_E_eddy,
+            'spectrum_k': spec_kbins if spec_kbins is not None
+                          else np.zeros(0, dtype=np.float32),
+        }
+        if rec is not None:
+            rec.close()
+        solution[:, -1, ...] = state.out() # B T C H W
+        return solution, diagnostics
